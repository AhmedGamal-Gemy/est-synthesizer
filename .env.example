# ═══════════════════════════════════════════════════════════════════════════════
#  Server
# ═══════════════════════════════════════════════════════════════════════════════
HOST=127.0.0.1
PORT=8080

# ═══════════════════════════════════════════════════════════════════════════════
#  Mistral AI (LLM)  —  https://console.mistral.ai
# ═══════════════════════════════════════════════════════════════════════════════
MISTRAL_API_KEY=change-me
MISTRAL_RATE_LIMIT=1.0
LITELLM_PROXY_URL=http://localhost:4000

# ═══════════════════════════════════════════════════════════════════════════════
#  Qdrant (Vector Database)  —  run via: docker compose up -d
# ═══════════════════════════════════════════════════════════════════════════════
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_LONG=long_passages
QDRANT_COLLECTION_SHORT=short_passages

# ═══════════════════════════════════════════════════════════════════════════════
#  Embedding Model  —  local Sentence-Transformer
# ═══════════════════════════════════════════════════════════════════════════════
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_VECTOR_SIZE=1024
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages: 

# ═══════════════════════════════════════════════════════════════════════════════
#  Local File Paths
# ═══════════════════════════════════════════════════════════════════════════════
SQLITE_PATH=data/db/est.db
GENERATED_PDF_PATH=data/generated/

# ═══════════════════════════════════════════════════════════════════════════════
#  Scraper — Project Gutenberg (Gutendex API)
# ═══════════════════════════════════════════════════════════════════════════════
GUTENDEX_BASE_URL=https://gutendex.com/books
GUTENDEX_MAX_BOOKS=200
GUTENDEX_REQUEST_TIMEOUT=15.0
GUTENDEX_PASSAGE_TIMEOUT=30.0
GUTENDEX_MIN_AUTHOR_BIRTH_YEAR=1700

# ═══════════════════════════════════════════════════════════════════════════════
#  LLM Generation Pipeline
# ═══════════════════════════════════════════════════════════════════════════════
LLM_MODEL=mistral/mistral-small-latest
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_SECONDS=2
